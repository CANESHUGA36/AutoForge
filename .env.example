# Copy this file to .env and fill in your values.
# .env is git-ignored and never committed.

# ========================================
# DeepSeek 文本模型（Builder / Reviewer / SprintMaster / Architect）
# ========================================
OPENAI_API_KEY=your-deepseek-key-here
OPENAI_BASE_URL=https://api.deepseek.com/v1
HARNESS_MODEL=deepseek-chat

# ========================================
# MiniMax 搜索/图片工具（search_web / analyze_image / generate_image）
# ========================================
MINIMAX_API_KEY=your-minimax-key-here
MINIMAX_BASE_URL=https://api.minimaxi.com

# 如果图片生成要用不同的 key，可以单独设置（否则 fallback 到 MINIMAX_API_KEY）
# GENERATE_IMAGE_API_KEY=

# ========================================
# 项目路径
# ========================================
# Parent folder for auto-generated runs (default ./projects). Docker compose sets /projects.
# HARNESS_PROJECTS_DIR=./projects

# ========================================
# 大组模式阈值
# ========================================
GROUP_PASS_THRESHOLD=0.70
OVERALL_PASS_THRESHOLD=0.75

# ========================================
# Agent 迭代限制（已适配 DeepSeek 1M 上下文）
# ========================================
MAX_AGENT_ITERATIONS=100
MAX_ITERATIONS_ARCHITECT=30
MAX_ITERATIONS_SPRINT_MASTER=15
MAX_ITERATIONS_BUILDER=120
MAX_ITERATIONS_REVIEWER=80

# ========================================
# Token 阈值（已适配 DeepSeek 1M 上下文）
# ========================================
COMPRESS_THRESHOLD=600000
RESET_THRESHOLD=900000

# ========================================
# Dev server
# ========================================
DEV_SERVER_URL=http://localhost:5173

# ========================================
# 功能开关
# ========================================
CONTRACT_TEST_ENABLED=true
REACT_DEVTOOLS_ENABLED=true

# ========================================
# 已废弃（大组模式下不再使用）
# ========================================
# 旧维度阈值和权重已移除，Reviewer 现在自主判定 PASS/FAIL。
