# Copy this file to .env and fill in your values.
# .env is git-ignored and never committed.

# --- Required ---
OPENAI_API_KEY=sk-your-key-here
OPENAI_BASE_URL=https://api.openai.com/v1
HARNESS_MODEL=gpt-4o

# Optional: Image generation API key (generate_image tool). If unset, OPENAI_API_KEY is used.
# GENERATE_IMAGE_API_KEY=

# --- Optional tuning ---
# Parent folder for auto-generated runs (default ./projects). Docker compose sets /projects.
# HARNESS_PROJECTS_DIR=./projects

# MAX_HARNESS_ROUNDS removed - now using dynamic round calculation based on project complexity
PASS_THRESHOLD=7.0
MAX_AGENT_ITERATIONS=100

# --- Per-dimension score thresholds (sprint fails if any dimension is below) ---
THRESHOLD_FUNCTIONALITY=5.0
THRESHOLD_DESIGN_QUALITY=4.0
THRESHOLD_ORIGINALITY=3.0
THRESHOLD_CRAFT=3.0

# --- Additional optional configs (see config.py for full list) ---
# SPRINT_PASS_THRESHOLD=6.0
# SIGNIFICANT_DROP=1.0
# SPRINT_PASS_RATE_THRESHOLD=0.70
# CONTRACT_PASS_RATE_THRESHOLD=0.75
# COMPRESS_THRESHOLD=180000
# RESET_THRESHOLD=200000
# MAX_ITERATIONS_ARCHITECT=30
# MAX_ITERATIONS_SPRINT_MASTER=15
# MAX_ITERATIONS_BUILDER=60
# MAX_ITERATIONS_REVIEWER=50
# MAX_ITERATIONS_JUDGE=15
# HARNESS_WORKSPACE=./workspace
# UNIT_TEST_THRESHOLD=0.0
