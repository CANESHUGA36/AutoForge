# Copy this file to .env and fill in your values.
# .env is git-ignored and never committed.

# --- Required ---
OPENAI_API_KEY=sk-your-key-here
OPENAI_BASE_URL=https://api.openai.com/v1
HARNESS_MODEL=gpt-4o

# Optional: Image generation API key (generate_image tool). If unset, OPENAI_API_KEY is used.
# GENERATE_IMAGE_API_KEY=

# --- Optional tuning ---
# Parent folder for auto-generated runs (default ./projects). Docker compose sets /projects.
# HARNESS_PROJECTS_DIR=./projects

# Big-group mode thresholds
GROUP_PASS_THRESHOLD=0.70
OVERALL_PASS_THRESHOLD=0.75

# Agent iteration limits
MAX_AGENT_ITERATIONS=100
MAX_ITERATIONS_ARCHITECT=30
MAX_ITERATIONS_SPRINT_MASTER=15
MAX_ITERATIONS_BUILDER=60
MAX_ITERATIONS_REVIEWER=50

# Token thresholds (200K context model)
COMPRESS_THRESHOLD=180000
RESET_THRESHOLD=200000

# Dev server
DEV_SERVER_URL=http://localhost:5173

# Feature group validation (Reviewer autonomously uses these when needed)
CONTRACT_TEST_ENABLED=true
REACT_DEVTOOLS_ENABLED=true

# --- Deprecated (kept for backward compatibility) ---
# Old dimension thresholds and weights are no longer used in big-group mode.
# Reviewer now makes autonomous pass/fail decisions.
